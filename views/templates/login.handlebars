<div class="container d-flex justify-content-center aling-items-center vh-110">
<div class="card p-4 shadow-sm cardLogin">
    <h2 class="text-center">Iniciar Sesion</h2>

    <form action="/api/sessions/login" id="loginForm" method="post">

    <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input type="email"class="form-control"name="email" required placeholder="Ingrese email"/>
    </div>

    <div class="mb-3">
        <label  for="password"  class="form-label" placeholder="Ingrese contraseña" >Password</label>
        <input type="password" class="form-control" name="password" required placeholder="Ingrese contraseña"/>
    </div>

    <button type="submit" class="btn btn-primary w-100">Iniciar Sesion</button>


    <div class="text-center mt-3">
        <button class="btn btn-dark w-100"><a href="/api/sessions/github">Iniciar Sesion con Github</a></button>

        <button class="btn btn-ligth w-100"><a href="/api/sessions/viewRegister">Registrarse</a></button>
    </div>

    </form>
</div>
</div>